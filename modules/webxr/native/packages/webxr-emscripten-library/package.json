{
	"name": "@godotengine/webxr-emscripten-library",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc && tsc-alias",
		"clean": "shx rm -rf ./dist && shx rm -f tsconfig.tsbuildinfo"
	},
	"exports": {
		".": "./dist/index.js",
