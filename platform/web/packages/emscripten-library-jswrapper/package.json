{
	"name": "@godotengine/emscripten-library-jswrapper",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "corepack pnpm run build:external-global && corepack pnpm run build:ts && corepack pnpm run build:library",
		"build:external-global": "external-global-d-ts-builder \"#/external/index.ts\" && corepack pnpm run lint:external-global",
		"build:ts": "tsdown",
		"build:library": "emscripten-builder --name emscripten-library-jswrapper ./libraries/index.js",
		"lint": "eslint . && prettier .",
		"lint:fix": "eslint --fix . && prettier --write .",
		"lint:external-global": "eslint --fix ./src/types/external_global.d.ts && prettier --write ./src/types/external_global.d.ts"
	},
	"exports": {
		".": "./dist/index.js",
		"./external": "./dist/external/index.js",
		"./libraries": "./dist/libraries/index.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"./dist/types/global.d.ts"
	],
	"dependencies": {
		"@godotengine/emscripten-library-base": "workspace:^"
	},
	"devDependencies": {
		"@godotengine/config-eslint": "workspace:^",
		"@godotengine/config-prettier": "workspace:^",
		"@godotengine/config-stylelint": "workspace:^",
		"@godotengine/config-tsconfig-browser": "workspace:^",
		"@godotengine/config-tsconfig-tools": "workspace:^",
		"@godotengine/config-tsdown": "workspace:^",
		"@godotengine/emscripten-builder": "workspace:^",
		"@godotengine/emscripten-utils": "workspace:^",
		"@godotengine/external-global-d-ts-builder": "workspace:^",
		"@godotengine/utils": "workspace:^",
		"eslint": "^9.39.2",
		"prettier": "3.8.1",
		"shx": "^0.4.0",
		"tsc-alias": "^1.8.16",
		"tsdown": "^0.20.1",
		"turbo": "^2.8.1",
		"typescript": "^5.9.3",
		"unplugin-macros": "^0.18.7"
	}
}
