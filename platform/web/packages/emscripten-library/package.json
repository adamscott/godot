{
	"name": "@godotengine/emscripten-library",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm run build:typescript && pnpm run build:export",
		"build:typescript": "tsc",
		"build:export": "esbuild ./dist/index.js --bundle --outfile=./dist/index.bundle.js"
	},
	"exports": {
		"import": "./dist/index.js"
	},
	"types": "./dist/index.d.ts",
	"devDependencies": {
		"@godotengine/config-tsconfig-browser": "workspace:^",
		"@godotengine/config-tsconfig-tools": "workspace:^",
		"eslint": "^9.39.2",
		"prettier": "3.8.1",
		"stylelint": "^17.1.0",
		"typescript": "^5.9.3"
	}
}
