{
	"name": "@godotengine/emscripten-libraries",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm run build:typescript && pnpm run build:copy-globaldts",
		"build:typescript": "tsc && tsc-alias",
		"build:copy-globaldts": "shx mkdir -p ./dist/types/ && shx cp ./src/types/global.d.ts ./dist/types/ && tsc-alias"
	},
	"exports": {
		".": "./dist/index.js",
		"./types/global.d.ts": "./dist/types/global.d.ts"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"./dist/types/global.d.ts"
	],
	"devDependencies": {
		"@godotengine/config-tsconfig-browser": "workspace:^",
		"@godotengine/config-tsconfig-tools": "workspace:^",
		"@godotengine/emscripten-builder": "workspace:^",
		"@godotengine/emscripten-utils": "workspace:^",
		"@godotengine/utils": "workspace:^",
		"browserslist": "^4.28.1",
		"dedent": "^1.7.1",
		"esbuild": "^0.27.2",
		"esbuild-plugin-browserslist": "^2.0.0",
		"eslint": "^9.39.2",
		"prettier": "3.8.1",
		"shx": "^0.4.0",
		"stylelint": "^17.1.0",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"turbo": "^2.8.1",
		"typescript": "^5.9.3",
		"unplugin-macros": "^0.18.7"
	}
}
