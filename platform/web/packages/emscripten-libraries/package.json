{
	"name": "@godotengine/emscripten-libraries",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "corepack pnpm run build:typescript",
		"build:typescript": "corepack pnpm run build:typescript-compile && corepack pnpm run build:typescript-alias",
		"build:typescript-compile": "tsc",
		"build:typescript-alias": "tsc-alias",
		"clean": "shx rm -rf ./dist && shx rm -f tsconfig.tsbuildinfo"
	},
	"exports": {
		".": "./dist/index.js",
		"./external": "./dist/external/index.js",
		"./libraries": "./dist/libraries/index.js"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"./dist/types/global.d.ts"
	],
	"devDependencies": {
		"@godotengine/config-tsconfig-browser": "workspace:^",
		"@godotengine/config-tsconfig-tools": "workspace:^",
		"@godotengine/emscripten-builder": "workspace:^",
		"@godotengine/emscripten-utils": "workspace:^",
		"@godotengine/utils": "workspace:^",
		"@types/webxr": "^0.5.24",
		"browserslist": "^4.28.1",
		"dedent": "^1.7.1",
		"esbuild": "^0.27.2",
		"esbuild-plugin-browserslist": "^2.0.0",
		"eslint": "^9.39.2",
		"prettier": "3.8.1",
		"shx": "^0.4.0",
		"stylelint": "^17.1.0",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"turbo": "^2.8.1",
		"typescript": "^5.9.3",
		"unplugin-macros": "^0.18.7"
	}
}
