{
	"name": "@godotengine/emscripten-utils",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "corepack pnpm run build:external-global && corepack pnpm run build:ts",
		"build:external-global": "emscripten-builder-externalglobaldts \"#/external/index.ts\" && corepack pnpm run lint:external-global",
		"build:ts": "tsdown",
		"lint": "eslint . && prettier .",
		"lint:fix": "eslint --fix . && prettier --write .",
		"lint:external-global": "eslint --fix ./src/types/external_global.d.ts && prettier --write ./src/types/external_global.d.ts",
		"clean": "shx rm -rf ./dist && shx rm -f tsconfig.tsbuildinfo"
	},
	"exports": {
		"./constants": "./dist/constants/index.js",
		"./external": "./dist/external/index.js",
		"./fetch": "./dist/fetch/index.js",
		"./types": "./dist/types/index.js",
		"./types/browser": "./dist/types/browser/index.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"devDependencies": {
		"@godotengine/config-prettier": "workspace:^",
		"@godotengine/config-tsconfig-browser": "workspace:^",
		"@godotengine/config-tsconfig-tools": "workspace:^",
		"@godotengine/config-tsdown": "workspace:^",
		"@godotengine/emscripten-builder-externalglobaldts": "workspace:^",
		"@godotengine/utils": "workspace:^",
		"@types/webxr": "^0.5.24",
		"eslint": "^9.39.2",
		"prettier": "3.8.1",
		"shx": "^0.4.0",
		"tsc-alias": "^1.8.16",
		"tsdown": "^0.20.1",
		"turbo": "^2.8.1",
		"typescript": "^5.9.3"
	}
}
