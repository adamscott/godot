{
	"extends": "@godotengine/config-tsconfig-browser",
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": "./src",
		"outDir": "./dist",
		"paths": {
			"#/*": ["./src/*"]
		}
	},
	"references": [{ "path": "./tsconfig.tools.json" }, { "path": "./tsconfig.audio.json" }],
	"include": ["./src/**/*", "./src/shared/**/*"],
	"exclude": ["./src/workers/**/*"]
}
